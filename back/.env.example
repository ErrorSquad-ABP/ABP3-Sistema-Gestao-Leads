# Copie para `.env` (ou crie `.env.local` para sobrescrever só no seu ambiente).
# Carregamento: `dotenv` lê `.env` e depois `.env.local` com override — ver `src/config/env.ts`.
# Não commite `.env` nem `.env.local`.

# URL pública da API (ex.: Swagger, links)
APP_URL=http://localhost:3001

# PostgreSQL — alinhado ao Compose (`localhost:5433` no host → `lead_management`).
# Ajuste usuário, senha e host se usar outro banco local.
DATABASE_URL=postgresql://abp:abp@localhost:5433/lead_management

NODE_ENV=development

# Porta HTTP do Nest (`main.ts` / `env.port`)
PORT=3001

# Legado / outros fluxos (mantido por compatibilidade com compose antigo)
JWT_SECRET=replace_with_a_strong_secret

# Redis — sessões JWT (refresh rotation + blacklist por jti)
REDIS_URL=redis://127.0.0.1:6379

# JWT RS256 — par PEM (obrigatório para subir o AuthModule).
# Uma linha no .env, com \n para quebras: -----BEGIN...-----\\nMIIE...\\n-----END...-----
# Geração local:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
#   node -e "console.log(require('fs').readFileSync('private.pem','utf8').replace(/\\n/g,'\\\\n'))"
JWT_ACCESS_PRIVATE_KEY=
JWT_ACCESS_PUBLIC_KEY=
# Opcional: par RSA só para refresh (reduz impacto se a chave de access vazar). Omita ambos para reutilizar as chaves de access.
# JWT_REFRESH_PRIVATE_KEY=
# JWT_REFRESH_PUBLIC_KEY=
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
JWT_ISSUER=abp3-leads-api
# Opcional: claim `aud` em access/refresh (sign + verify). Omita para não usar audience.
# JWT_AUDIENCE=abp3-leads-api

# Rate limit auth (Redis): tentativas permitidas por janela (padrões se omitido)
# AUTH_RATE_LIMIT_LOGIN_MAX=30
# AUTH_RATE_LIMIT_LOGIN_WINDOW_SEC=60
# AUTH_RATE_LIMIT_REFRESH_MAX=60
# AUTH_RATE_LIMIT_REFRESH_WINDOW_SEC=60

# Origens do front permitidas no CORS com credentials (vírgula)
FRONTEND_ORIGINS=http://localhost:3000

# Nomes dos cookies HttpOnly (opcional)
# AUTH_COOKIE_ACCESS=access_token
# AUTH_COOKIE_REFRESH=refresh_token
