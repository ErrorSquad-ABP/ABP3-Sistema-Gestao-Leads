# Copie para `.env` (ou crie `.env.local` para sobrescrever só no seu ambiente).
# Carregamento: `dotenv` lê `.env` e depois `.env.local` com override — ver `src/config/env.ts`.
# Não commite `.env` nem `.env.local`.

# URL pública da API (ex.: Swagger, links)
APP_URL=http://localhost:3001

# PostgreSQL — alinhado ao Compose (`localhost:5433` no host → `lead_management`).
# Ajuste usuário, senha e host se usar outro banco local.
DATABASE_URL=postgresql://abp:abp@localhost:5433/lead_management

NODE_ENV=development

# Porta HTTP do Nest (`main.ts` / `env.port`)
PORT=3001

# Obrigatório quando houver fluxos que validam presença do segredo (ex.: auth JWT).
JWT_SECRET=replace_with_a_strong_secret
