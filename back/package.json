{
	"name": "back",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "npm run prisma:generate && tsx watch src/main.ts",
		"build": "npm run prisma:generate && tsc -p tsconfig.build.json",
		"prisma:generate": "prisma generate --config prisma.config.ts",
		"prisma:migrate:dev": "prisma migrate dev --config prisma.config.ts",
		"prisma:migrate:deploy": "prisma migrate deploy --config prisma.config.ts",
		"prisma:seed": "prisma db seed --config prisma.config.ts",
		"start": "node dist/main.js",
		"start:dev": "npm run prisma:generate && tsx watch src/main.ts",
		"start:prod": "node dist/main.js",
		"typecheck": "tsc --noEmit -p tsconfig.json"
	},
	"dependencies": {
		"@nestjs/common": "11.1.17",
		"@nestjs/core": "11.1.17",
		"@nestjs/platform-express": "11.1.17",
		"@nestjs/swagger": "11.2.6",
		"@prisma/adapter-pg": "^7.6.0",
		"@prisma/client": "^7.6.0",
		"pg": "^8.20.0",
		"reflect-metadata": "0.2.2",
		"rxjs": "7.8.2",
		"swagger-ui-express": "5.0.1"
	},
	"devDependencies": {
		"@types/node": "25.5.0",
		"dotenv": "^16.6.1",
		"prisma": "^7.6.0",
		"tsx": "4.21.0"
	},
	"prisma": {
		"seed": "tsx prisma/seed.ts"
	}
}
