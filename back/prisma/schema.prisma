generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ATTENDANT
  MANAGER
  GENERAL_MANAGER
  ADMIN
}

enum LeadSource {
  WEBSITE
  WHATSAPP
  PHONE
  WALK_IN
  INDICATION
  OTHER
  INSTAGRAM
  FACEBOOK
  MERCADO_LIVRE
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  NEGOTIATING
  CONVERTED
  LOST
}

enum DealImportance {
  COLD
  WARM
  HOT
}

enum DealStage {
  INITIAL_CONTACT
  NEGOTIATION
  PROPOSAL
  CLOSING
}

enum DealStatus {
  OPEN
  WON
  LOST
}

enum DealHistoryField {
  IMPORTANCE
  STAGE
  STATUS
  TITLE
  VALUE
  VEHICLE
}

enum VehicleStatus {
  AVAILABLE
  RESERVED
  SOLD
  INACTIVE
}

enum SupportedFuelType {
  GASOLINE
  ETHANOL
  FLEX
  DIESEL
  ELECTRIC
  HYBRID
  PLUG_IN_HYBRID
  CNG
}

model AccessGroup {
  id            String    @id @default(uuid()) @db.Uuid
  name          String    @unique
  description   String
  baseRole      UserRole?
  featureKeys   Json
  isSystemGroup Boolean   @default(false)
  users         User[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model User {
  id            String       @id @default(uuid()) @db.Uuid
  name          String
  email         String       @unique
  password      String
  role          UserRole
  accessGroupId String?      @db.Uuid
  accessGroup   AccessGroup? @relation(fields: [accessGroupId], references: [id], onDelete: SetNull)

  memberTeams   Team[]       @relation("TeamMembers")
  managedTeams  Team[]       @relation("TeamManager")

  ownedLeads    Lead[]       @relation("LeadOwner")
  auditLogs     AuditLog[]
  authSessions  AuthSession[]

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model AuthSession {
  id               String    @id @db.Uuid
  userId           String    @db.Uuid
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokenHash String    @db.VarChar(64)
  expiresAt        DateTime
  revokedAt        DateTime?
  lastUsedAt       DateTime?
  userAgent        String?
  ipAddress        String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([userId])
  @@map("auth_sessions")
}

model Team {
  id          String     @id @default(uuid()) @db.Uuid
  name        String

  storeId     String     @db.Uuid
  store       Store      @relation(fields: [storeId], references: [id], onDelete: Restrict)

  members     User[]     @relation("TeamMembers")
  managerId   String?    @db.Uuid
  manager     User?      @relation("TeamManager", fields: [managerId], references: [id], onDelete: SetNull)

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Store {
  id          String     @id @default(uuid()) @db.Uuid
  name        String
  teams       Team[]
  leads       Lead[]
  vehicles    Vehicle[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Customer {
  id         String   @id @default(uuid()) @db.Uuid
  name       String
  email      String?  @unique
  phone      String?
  cpf        String?  @unique @db.VarChar(11)
  leads      Lead[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Lead {
  id          String      @id @default(uuid()) @db.Uuid
  customerId  String      @db.Uuid
  storeId     String      @db.Uuid
  ownerUserId String?     @db.Uuid
  source      LeadSource
  status      LeadStatus  @default(NEW)
  vehicleInterestText String?
  customer    Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  store       Store       @relation(fields: [storeId], references: [id], onDelete: Restrict)
  owner       User?       @relation("LeadOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  deals       Deal[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Vehicle {
  id                String            @id @default(uuid()) @db.Uuid
  storeId            String            @db.Uuid
  brand              String
  model              String
  version            String?
  modelYear          Int
  manufactureYear    Int?
  color              String?
  mileage            Int
  supportedFuelType  SupportedFuelType
  price              Decimal           @db.Decimal(12, 2)
  status             VehicleStatus
  plate              String?
  vin                String?
  store              Store             @relation(fields: [storeId], references: [id], onDelete: Restrict)
  deals              Deal[]
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@index([storeId])
}

model Deal {
  id          String          @id @default(uuid()) @db.Uuid
  leadId      String          @db.Uuid
  vehicleId   String          @db.Uuid
  title       String
  value       Decimal?        @db.Decimal(12, 2)
  importance  DealImportance
  stage       DealStage
  status      DealStatus
  closedAt    DateTime?
  lead        Lead            @relation(fields: [leadId], references: [id], onDelete: Cascade)
  vehicle     Vehicle         @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  history     DealHistory[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([leadId])
  @@index([vehicleId])
}

model DealHistory {
  id          String           @id @default(uuid()) @db.Uuid
  dealId      String           @db.Uuid
  deal        Deal             @relation(fields: [dealId], references: [id], onDelete: Cascade)
  field       DealHistoryField
  fromValue   String?
  toValue     String
  actorUserId String?          @db.Uuid
  createdAt   DateTime         @default(now())

  @@index([dealId, createdAt])
}

model AuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  actorUserId String?  @db.Uuid
  action      String
  entityName  String
  entityId    String?
  metadata    Json?
  actorUser   User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
}
