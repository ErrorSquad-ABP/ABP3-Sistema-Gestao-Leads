{
	"name": "abp3-sistema-gestao-leads",
	"version": "0.1.0",
	"private": true,
	"description": "Single repository do Sistema de Gestao de Leads com Dashboard Analitico da ErrorSquad-ABP",
	"workspaces": [
		"front",
		"back"
	],
	"engines": {
		"node": ">=22.0.0",
		"npm": ">=10.0.0"
	},
	"scripts": {
		"dev": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up --build",
		"dev:down": "docker compose -f docker-compose.yml -f docker-compose.dev.yml down",
		"compose:up": "docker compose up --build",
		"compose:down": "docker compose down",
		"db:generate": "npm run prisma:generate -w back",
		"db:migrate": "npm run prisma:migrate:deploy -w back",
		"db:migrate:dev": "npm run prisma:migrate:dev -w back",
		"db:seed": "npm run prisma:seed -w back",
		"guard:root-package": "node scripts/check-root-package.mjs",
		"format": "biome format --write .",
		"format:check": "biome format .",
		"lint": "biome lint --write .",
		"lint:check": "biome lint .",
		"check": "biome check --write .",
		"check:ci": "biome ci .",
		"lint:eslint": "eslint front/src back/src --ext .ts,.tsx --max-warnings 0",
		"lint:eslint:blocking": "npm run lint:eslint",
		"typecheck": "npm run typecheck --workspaces --if-present",
		"quality:gate:blocking": "npm run guard:root-package && npm run format:check && npm run lint:check && npm run typecheck && npm run lint:eslint && npm run build",
		"quality:gate:advisory": "npm run guard:root-package && npm run format:check && npm run lint:check && npm run lint:eslint",
		"build": "npm run build --workspaces --if-present",
		"security:check": "node scripts/security-check.mjs"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.8",
		"@eslint/js": "9.39.4",
		"@typescript-eslint/eslint-plugin": "8.57.1",
		"@typescript-eslint/parser": "8.57.1",
		"eslint": "9.39.4",
		"eslint-plugin-no-unsanitized": "4.1.5",
		"eslint-plugin-react": "7.37.5",
		"eslint-plugin-security": "4.0.0",
		"typescript": "5.9.3"
	},
	"overrides": {
		"@nestjs/common": "11.1.18",
		"@nestjs/core": "11.1.18",
		"@nestjs/platform-express": "11.1.18",
		"defu": "6.1.6",
		"lodash": "4.18.1",
		"path-to-regexp": "8.4.2",
		"minimatch@10.2.4": {
			"brace-expansion": "5.0.5"
		},
		"minimatch@3.1.5": {
			"brace-expansion": "1.1.13"
		},
		"picomatch": "4.0.4"
	}
}
