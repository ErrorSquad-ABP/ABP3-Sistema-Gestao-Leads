{
	"name": "back",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "npm run prisma:generate && nest start --watch",
		"build": "npm run prisma:generate && nest build",
		"prisma:generate": "prisma generate --config prisma.config.ts",
		"prisma:migrate:dev": "prisma migrate dev --config prisma.config.ts",
		"prisma:migrate:deploy": "prisma migrate deploy --config prisma.config.ts",
		"prisma:seed": "prisma db seed --config prisma.config.ts",
		"start": "nest start",
		"start:dev": "npm run prisma:generate && nest start --watch",
		"start:debug": "nest start --debug --watch",
		"start:prod": "node dist/main.js",
		"typecheck": "npm run prisma:generate && tsc --noEmit -p tsconfig.json",
		"test": "tsx --test \"src/**/*.spec.ts\"",
		"smoke:http": "node scripts/smoke-http.mjs"
	},
	"dependencies": {
		"@nestjs/common": "11.1.18",
		"@nestjs/core": "11.1.18",
		"@nestjs/jwt": "^11.0.2",
		"@nestjs/passport": "^11.0.5",
		"@nestjs/platform-express": "11.1.18",
		"@nestjs/swagger": "11.2.7",
		"@prisma/adapter-pg": "^7.6.0",
		"@prisma/client": "^7.6.0",
		"@scalar/nestjs-api-reference": "^1.1.5",
		"argon2": "^0.44.0",
		"class-transformer": "^0.5.1",
		"class-validator": "^0.14.4",
		"cookie-parser": "^1.4.7",
		"dinero.js": "^2.0.2",
		"dotenv": "^16.6.1",
		"express": "^5.2.1",
		"helmet": "^8.1.0",
		"passport": "^0.7.0",
		"passport-jwt": "^4.0.1",
		"pg": "^8.20.0",
		"reflect-metadata": "0.2.2",
		"rxjs": "7.8.2",
		"swagger-ui-express": "5.0.1"
	},
	"devDependencies": {
		"@nestjs/cli": "11.0.17",
		"@types/cookie-parser": "^1.4.10",
		"@types/node": "25.5.0",
		"@types/passport-jwt": "^4.0.1",
		"prisma": "^7.6.0",
		"tsx": "4.21.0",
		"typescript": "5.9.3"
	},
	"prisma": {
		"seed": "tsx prisma/seed.ts"
	}
}
