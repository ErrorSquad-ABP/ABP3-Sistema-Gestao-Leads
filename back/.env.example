# Copie para `.env` (ou crie `.env.local` para sobrescrever só no seu ambiente).
# Carregamento: `dotenv` lê `.env` e depois `.env.local` com override — ver `src/config/env.ts`.
# Não commite `.env` nem `.env.local`.

# URL pública da API (ex.: Swagger, links)
APP_URL=http://localhost:3001

# PostgreSQL — o modo secundário `docker-compose.local.yml` publica `localhost:5433`.
# Ajuste usuário, senha e host se preferir banco remoto ou outro PostgreSQL local.
DATABASE_URL=postgresql://abp:abp@localhost:5433/lead_management

NODE_ENV=development

# Porta HTTP do Nest (`main.ts` / `env.port`)
PORT=3001

# Express `trust proxy`: número de proxies confiáveis na frente da API (ex.: 1 com nginx).
# Com `false`/vazio, o rate limit de auth usa só o IP da ligação TCP (clientes não podem forjar X-Forwarded-For).
# Em produção atrás de reverse proxy, defina tipicamente `TRUST_PROXY=1`.
# TRUST_PROXY=1

# Legado / outros fluxos (mantido por compatibilidade com compose antigo)
JWT_SECRET=replace_with_a_strong_secret

# JWT RS256 — par PEM (obrigatório para subir o AuthModule).
# Uma linha no .env, com \n para quebras: -----BEGIN...-----\\nMIIE...\\n-----END...-----
# Geração local:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
#   node -e "console.log(require('fs').readFileSync('private.pem','utf8').replace(/\\n/g,'\\\\n'))"
JWT_ACCESS_PRIVATE_KEY=
JWT_ACCESS_PUBLIC_KEY=
# TTL do access (ex. 15m, 1h)
JWT_ACCESS_EXPIRES=1h
# TTL da sessão de refresh opaca (persistida em Postgres)
JWT_REFRESH_EXPIRES=7d
# Opcional: pepper aplicado antes do SHA-256 do segredo do refresh
# REFRESH_TOKEN_PEPPER=
JWT_ISSUER=abp3-leads-api
# Claim `aud` (sign + verify). Obrigatório quando NODE_ENV=production.
JWT_AUDIENCE=abp3-leads-api

# Rate limit login em memória (por processo): tentativas por janela
# AUTH_RATE_LIMIT_LOGIN_MAX=30
# AUTH_RATE_LIMIT_LOGIN_WINDOW_SEC=60
# Rate limit refresh (por processo), tipicamente por IP
# AUTH_RATE_LIMIT_REFRESH_MAX=60
# AUTH_RATE_LIMIT_REFRESH_WINDOW_SEC=60
# Rate limit alteração do próprio e-mail/senha (IP + userId do JWT)
# AUTH_RATE_LIMIT_CREDENTIAL_UPDATE_MAX=20
# AUTH_RATE_LIMIT_CREDENTIAL_UPDATE_WINDOW_SEC=60

# Máximo de sessões de refresh ativas por utilizador (`0` = ilimitado). Ao exceder, revoga-se a mais antiga.
# AUTH_MAX_ACTIVE_SESSIONS_PER_USER=0

# Origens do front permitidas no CORS com credentials (vírgula)
FRONTEND_ORIGINS=http://localhost:3000

# Seed Prisma (`npm run prisma:seed` em /back): `minimal` (auth + equipas/lojas) ou `dashboard` (CSV completo)
# SEED_MODE=minimal
# Palavra-passe comum aos utilizadores seed quando SEED_MODE=minimal (e alinhada ao CSV em dashboard)
# SEED_DEFAULT_PASSWORD=admin123

# Nome do cookie HttpOnly do access (opcional)
# AUTH_COOKIE_ACCESS=access_token
# Cookie HttpOnly do refresh opaco (opcional)
# AUTH_COOKIE_REFRESH=refresh_token
# SameSite: lax (padrão) | strict | none (exige HTTPS/secure; com `none` avalie anti-CSRF nos POST /auth/refresh e /auth/logout)
# AUTH_COOKIE_SAMESITE=lax
