# Copie para `.env` (ou crie `.env.local` para sobrescrever sĂ³ no seu ambiente).
# Carregamento: `dotenv` lĂª `.env` e depois `.env.local` com override â€” ver `src/config/env.ts`.
# NĂ£o commite `.env` nem `.env.local`.

# URL pĂºblica da API (ex.: Swagger, links)
APP_URL=http://localhost:3001

# PostgreSQL â€” alinhado ao Compose (`localhost:5433` no host â†’ `lead_management`).
# Ajuste usuĂ¡rio, senha e host se usar outro banco local.
DATABASE_URL=postgresql://abp:abp@localhost:5433/lead_management

NODE_ENV=development

# Porta HTTP do Nest (`main.ts` / `env.port`)
PORT=3001

# Express `trust proxy`: nĂºmero de proxies confiĂ¡veis na frente da API (ex.: 1 com nginx).
# Com `false`/vazio, o rate limit de auth usa sĂ³ o IP da ligaĂ§Ă£o TCP (clientes nĂ£o podem forjar X-Forwarded-For).
# Em produĂ§Ă£o atrĂ¡s de reverse proxy, defina tipicamente `TRUST_PROXY=1`.
# TRUST_PROXY=1

# Legado / outros fluxos (mantido por compatibilidade com compose antigo)
JWT_SECRET=replace_with_a_strong_secret

# JWT RS256 â€” par PEM (obrigatĂ³rio para subir o AuthModule).
# Uma linha no .env, com \n para quebras: -----BEGIN...-----\\nMIIE...\\n-----END...-----
# GeraĂ§Ă£o local:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
#   node -e "console.log(require('fs').readFileSync('private.pem','utf8').replace(/\\n/g,'\\\\n'))"
JWT_ACCESS_PRIVATE_KEY=
JWT_ACCESS_PUBLIC_KEY=
# TTL do access (ex. 15m, 1h)
JWT_ACCESS_EXPIRES=1h
# TTL da sessĂ£o de refresh opaca (persistida em Postgres)
JWT_REFRESH_EXPIRES=7d
# Opcional: pepper aplicado antes do SHA-256 do segredo do refresh
# REFRESH_TOKEN_PEPPER=
JWT_ISSUER=abp3-leads-api
# Claim `aud` (sign + verify). ObrigatĂ³rio quando NODE_ENV=production.
JWT_AUDIENCE=abp3-leads-api

# Rate limit login em memĂ³ria (por processo): tentativas por janela
# AUTH_RATE_LIMIT_LOGIN_MAX=30
# AUTH_RATE_LIMIT_LOGIN_WINDOW_SEC=60
# Rate limit refresh (por processo), tipicamente por IP
# AUTH_RATE_LIMIT_REFRESH_MAX=60
# AUTH_RATE_LIMIT_REFRESH_WINDOW_SEC=60

# MĂ¡ximo de sessĂµes de refresh ativas por utilizador (`0` = ilimitado). Ao exceder, revoga-se a mais antiga.
# AUTH_MAX_ACTIVE_SESSIONS_PER_USER=0

# Origens do front permitidas no CORS com credentials (vĂ­rgula)
FRONTEND_ORIGINS=http://localhost:3000

# Nome do cookie HttpOnly do access (opcional)
# AUTH_COOKIE_ACCESS=access_token
# Cookie HttpOnly do refresh opaco (opcional)
# AUTH_COOKIE_REFRESH=refresh_token
# SameSite: lax (padrĂ£o) | strict | none (exige HTTPS/secure; com `none` avalie anti-CSRF nos POST /auth/refresh e /auth/logout)
# AUTH_COOKIE_SAMESITE=lax
